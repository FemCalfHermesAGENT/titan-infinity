# Hermes Agent Environment Configuration
# API Keys

# OpenRouter (primary provider)
OPENROUTER_API_KEY="***"

# Google AI
GOOGLE_API_KEY="***"

# Anthropic
ANTHROPIC_API_KEY="***"

# OpenAI
OPENAI_API_KEY="***"

# Hermes Configuration
HERMES_HOME="/s/hermes/.hermes"
HERMES_WORKSPACE="/s/hermes/workspace"
HERMES_LOGS="/s/hermes/logs"

# Node Configuration
NODE_ENV="production"

# Docker Configuration
COMPOSE_PROJECT_NAME="hermes"
